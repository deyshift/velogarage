# Strava OAuth app credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Public URL of this API — used to build the Strava OAuth redirect_uri.
# Local dev: http://localhost:8000    Production: https://velogarage.onrender.com
API_PUBLIC_URL=http://localhost:8000

# Upstash Redis (durable garage storage), from the Upstash console.
# Saving is disabled until BOTH are set.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — where web logins return to; defaults to the GitHub Pages app.
# WEB_APP_URL=https://deyshift.github.io/velogarage/app

# Optional — comma-separated CORS allow-list; defaults to the web app's origin.
# ALLOWED_ORIGINS=http://localhost:5173
